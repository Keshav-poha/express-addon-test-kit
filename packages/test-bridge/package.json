{
  "name": "@express-addon-tests/test-bridge",
  "version": "0.1.0",
  "description": "In-process bridge that connects the iframe runtime and document sandbox runtime for cross-runtime testing",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Keshav-poha/express-addon-test-kit",
    "directory": "packages/test-bridge"
  },
  "bugs": {
    "url": "https://github.com/Keshav-poha/express-addon-test-kit/issues"
  },
  "keywords": [
    "express-addon",
    "adobe-express",
    "add-on",
    "testing",
    "mock",
    "sdk",
    "vitest",
    "jest",
    "bridge",
    "runtime"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc --project tsconfig.json && tsc --project tsconfig.cjs.json && node ../../scripts/postbuild.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "node -e \"const fs = require('fs'); ['dist', 'tsconfig.tsbuildinfo', 'tsconfig.cjs.tsbuildinfo'].forEach(p => fs.rmSync(p, { recursive: true, force: true }))\""
  },
  "dependencies": {},
  "devDependencies": {
    "@express-addon-tests/ui-sdk-mock": "workspace:*",
    "@express-addon-tests/doc-sdk-mock": "workspace:*",
    "typescript": "*",
    "vitest": "*"
  },
  "peerDependencies": {
    "@express-addon-tests/ui-sdk-mock": "workspace:*",
    "@express-addon-tests/doc-sdk-mock": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@express-addon-tests/ui-sdk-mock": { "optional": true },
    "@express-addon-tests/doc-sdk-mock": { "optional": true }
  },
  "publishConfig": {
    "access": "public"
  }
}
