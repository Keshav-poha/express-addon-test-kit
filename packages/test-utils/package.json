{
  "name": "@express-addon-tests/test-utils",
  "version": "0.1.0",
  "description": "Mock factories, event simulation helpers, and test runner setup for Express add-on testing",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Keshav-poha/express-addon-test-kit",
    "directory": "packages/test-utils"
  },
  "bugs": {
    "url": "https://github.com/Keshav-poha/express-addon-test-kit/issues"
  },
  "keywords": [
    "express-addon",
    "adobe-express",
    "add-on",
    "testing",
    "mock",
    "sdk",
    "vitest",
    "jest",
    "factories",
    "simulate"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./setup/vitest": {
      "types": "./dist/setup/vitest.d.ts",
      "import": "./dist/setup/vitest.js",
      "require": "./dist/cjs/setup/vitest.js"
    },
    "./setup/jest": {
      "types": "./dist/setup/jest.d.ts",
      "import": "./dist/setup/jest.js",
      "require": "./dist/cjs/setup/jest.js"
    },
    "./factories": {
      "types": "./dist/factories/index.d.ts",
      "import": "./dist/factories/index.js",
      "require": "./dist/cjs/factories/index.js"
    },
    "./simulate": {
      "types": "./dist/simulate/index.d.ts",
      "import": "./dist/simulate/index.js",
      "require": "./dist/cjs/simulate/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc --project tsconfig.json && tsc --project tsconfig.cjs.json && node ../../scripts/postbuild.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "node -e \"const fs = require('fs'); ['dist', 'tsconfig.tsbuildinfo', 'tsconfig.cjs.tsbuildinfo'].forEach(p => fs.rmSync(p, { recursive: true, force: true }))\""
  },
  "dependencies": {
    "@express-addon-tests/ui-sdk-mock": "workspace:*",
    "@express-addon-tests/doc-sdk-mock": "workspace:*",
    "@express-addon-tests/test-bridge": "workspace:*"
  },
  "devDependencies": {
    "typescript": "*",
    "vitest": "*"
  },
  "peerDependencies": {
    "vitest": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": { "optional": true }
  },
  "publishConfig": {
    "access": "public"
  }
}
