{
  "name": "@express-addon-tests/test-utils",
  "version": "0.0.0",
  "description": "Test factories, simulation helpers, and framework setup for Express add-on testing",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Keshav-poha/express-addon-test-kit",
    "directory": "packages/test-utils"
  },
  "bugs": {
    "url": "https://github.com/Keshav-poha/express-addon-test-kit/issues"
  },
  "keywords": [
    "express-addon",
    "add-on",
    "testing",
    "mock",
    "sdk",
    "vitest",
    "jest",
    "factories",
    "simulate"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./setup/vitest": {
      "import": "./dist/setup/vitest.js",
      "types": "./dist/setup/vitest.d.ts"
    },
    "./setup/jest": {
      "import": "./dist/setup/jest.js",
      "types": "./dist/setup/jest.d.ts"
    },
    "./factories": {
      "import": "./dist/factories/index.js",
      "types": "./dist/factories/index.d.ts"
    },
    "./simulate": {
      "import": "./dist/simulate/index.js",
      "types": "./dist/simulate/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@express-addon-tests/ui-sdk-mock": "workspace:*",
    "@express-addon-tests/doc-sdk-mock": "workspace:*",
    "@express-addon-tests/test-bridge": "workspace:*"
  },
  "devDependencies": {
    "typescript": "*",
    "vitest": "*"
  },
  "peerDependencies": {
    "vitest": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": { "optional": true }
  },
  "publishConfig": {
    "access": "public"
  }
}
